# Apple Disease Detector - Environment Configuration
# Copy this file to .env and modify as needed

# Model Configuration
MODEL_TYPE=mock
MODEL_PATH=
DEVICE=cpu
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45
IMG_SIZE=640

# Image Constraints
MAX_IMAGE_SIZE=4096
MIN_IMAGE_SIZE=64
MAX_FILE_SIZE_MB=16

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false
PROD=false

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# History
MAX_HISTORY=5000
HISTORY_TTL_SECONDS=86400

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# WebSocket
ENABLE_WEBSOCKET=true
WS_HEARTBEAT_INTERVAL=30

# Metrics
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=60
